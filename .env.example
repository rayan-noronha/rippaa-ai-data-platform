# ─────────────────────────────────────────────
# RIPPAA AI Data Platform — Environment Config
# ─────────────────────────────────────────────
# Copy this to .env and fill in your values.
# All variables are prefixed with RIPPAA_.

# ── Application ──────────────────────────────
RIPPAA_ENVIRONMENT=development
RIPPAA_DEBUG=true
RIPPAA_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────
RIPPAA_DATABASE_URL=postgresql://rippaa:rippaa_dev@localhost:5432/rippaa_platform

# ── Kafka ────────────────────────────────────
RIPPAA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── AWS / LocalStack ─────────────────────────
RIPPAA_AWS_REGION=ap-southeast-2
RIPPAA_AWS_ENDPOINT_URL=http://localhost:4566

# ── LLM ──────────────────────────────────────
RIPPAA_LLM_PROVIDER=bedrock
# RIPPAA_ANTHROPIC_API_KEY=sk-ant-...  # Only if using Anthropic directly

# ── API ──────────────────────────────────────
RIPPAA_API_HOST=0.0.0.0
RIPPAA_API_PORT=8000
RIPPAA_API_RATE_LIMIT=100
